{
  "skip_directories": [
    ".git",
    ".venv",
    "node_modules",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".idea",
    ".vscode",
    "dist",
    "build",
    "anonymized",
    "prowler_anonymized",
    "prowler_anonymized_final"
  ],
  "skip_extensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".pdf",
    ".zip",
    ".rar",
    ".7z",
    ".tar",
    ".gz",
    ".tgz",
    ".bz2",
    ".xz",
    ".pyc",
    ".so",
    ".dylib",
    ".exe",
    ".dll",
    ".class",
    ".jar",
    ".xlsx",
    ".docx",
    ".pptx"
  ],
  "skip_files": [],
  "anonymized_account_prefix": "100000000",
  "anonymized_account_id_regexes": [
    "^(\\d)\\1{11}$",
    "^123456789012$"
  ],
  "allowlist_regexes": [
    "example\\.com",
    "example\\.org",
    "test@example\\.com",
    "user@example\\.com",
    "dummy",
    "placeholder",
    "changeme",
    "redacted"
  ],
  "patterns": {
    "email_address": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
    "phone_number": "\\b(?:\\+?\\d{1,3}[\\s.-]?)?(?:\\(?\\d{2,3}\\)?[\\s.-]?)?\\d{3}[\\s.-]?\\d{4}\\b",
    "ssn": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
    "credit_card": "\\b(?:\\d[ -]*?){13,19}\\b",
    "aws_access_key": "AKIA[0-9A-Z]{16}",
    "aws_arn_account": "arn:aws[a-z-]*:[a-z0-9-]+:[a-z0-9-]*:\\d{12}:",
    "aws_account_id_assignment": "(?i)\\b(?:aws_)?account_id\\b\\s*[=:]\\s*['\\\"]?\\d{12}['\\\"]?",
    "aws_secret_access_key": "(?i)aws_secret_access_key\\s*[=:]\\s*['\\\"]?[A-Za-z0-9/+=]{40}['\\\"]?",
    "api_key_assignment": "(?i)(api_key|api_token|secret_key|access_token)\\s*[=:]\\s*['\\\"]?[A-Za-z0-9_\\-]{20,}['\\\"]?",
    "client_secret_assignment": "(?i)client_secret\\s*[=:]\\s*['\\\"]?[^\\s'\\\"]{8,}",
    "password_assignment": "(?i)(password|passwd|pwd|secret|token)\\s*[=:]\\s*['\\\"]?[^\\s'\\\"]{8,}",
    "bearer_token": "Bearer\\s+[A-Za-z0-9._\\-]{20,}",
    "github_pat": "github_pat_[A-Za-z0-9_]{20,}",
    "github_token": "gh[oprsu]_[A-Za-z0-9]{36}",
    "private_key_header": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
  }
}
